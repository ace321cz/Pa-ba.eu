<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pařba.eu | Team Speak server zdarma</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Kanit:wght@300;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root { 
            --accent-red: #ff3333; 
            --accent-blue: #007bff;
            --accent-glow-red: rgba(255, 51, 51, 0.6);
            --bg-dark: #08080a;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
        }
        
        body { 
            background-color: var(--bg-dark); 
            color: #fafafa; 
            font-family: 'Kanit', sans-serif; 
            margin: 0; 
            overflow-x: hidden;
        }

        /* ANIMOVANÉ PULZUJÍCÍ POZADÍ */
        .bg-wrapper {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: 
                radial-gradient(circle at 15% 25%, rgba(255, 51, 51, 0.1), transparent 35%),
                radial-gradient(circle at 85% 75%, rgba(0, 123, 255, 0.08), transparent 35%),
                linear-gradient(rgba(8, 8, 10, 0.9), rgba(8, 8, 10, 1)),
                url('https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1920');
            background-size: cover; background-position: center;
            z-index: -1;
            filter: grayscale(0.2);
            animation: backgroundPulse 10s ease-in-out infinite;
        }
        
        @keyframes backgroundPulse {
            0%, 100% { filter: grayscale(0.2) brightness(1); }
            50% { filter: grayscale(0.3) brightness(1.1); }
        }

        /* HERO SEKCE */
        .hero-section {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            position: relative;
            padding: 20px;
        }

        .main-title {
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(3.5rem, 15vw, 8rem);
            font-weight: 900;
            text-transform: uppercase;
            line-height: 0.9;
            margin-bottom: 5px;
            background: linear-gradient(180deg, #fff 50%, #888 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 25px var(--accent-glow-red));
        }

        .hero-desc {
            font-size: clamp(1.1rem, 3vw, 1.4rem);
            text-transform: uppercase;
            letter-spacing: 6px;
            color: var(--accent-red);
            font-weight: 800;
            margin-bottom: 50px;
        }

        /* IP BOX - GLASSMORPHISM DESIGN */
        .ip-card {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            padding: 25px 50px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            cursor: pointer;
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            position: relative;
        }
        
        .ip-card:hover {
            transform: scale(1.03);
            box-shadow: 0 15px 50px rgba(255, 51, 51, 0.4);
            border-color: rgba(255, 51, 51, 0.3);
        }

        .ip-card h2 {
            font-family: monospace;
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0;
            color: #fff;
        }

        .copy-info {
            position: absolute; bottom: 8px; left: 50%;
            transform: translateX(-50%);
            font-size: 0.7rem; color: #666; font-weight: bold; width: 100%;
        }

        /* LIVE STATUS BADGE */
        .live-badge {
            position: absolute; top: 30px; left: 30px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.95rem;
            display: flex; align-items: center; gap: 12px;
            backdrop-filter: blur(5px);
        }
        .live-dot { width: 10px; height: 10px; border-radius: 50%; background: #444; position: relative; }
        .live-dot.online { background: #00ff00; box-shadow: 0 0 15px #00ff00; }
        .live-dot.online::after { content: ""; position: absolute; width: 100%; height: 100%; background: inherit; border-radius: inherit; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3); opacity: 0; } }

        /* FEATURE SECTION */
        .game-grid { padding: 100px 0; background: linear-gradient(transparent, #050505); }
        
        .game-card {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 20px;
            padding: 50px 30px;
            height: 100%;
            transition: 0.4s;
            backdrop-filter: blur(5px);
            text-align: center;
        }
        
        .game-card:hover {
            background: rgba(255, 51, 51, 0.06);
            border-color: var(--accent-red);
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .game-card i {
            font-size: 3.5rem;
            color: var(--accent-red);
            margin-bottom: 25px;
            display: block;
            text-shadow: 0 0 15px rgba(255, 51, 51, 0.5);
        }

        .game-card h3 { 
            font-weight: 900; 
            text-transform: uppercase; 
            margin-bottom: 15px; 
            letter-spacing: 1px;
        }

        .ts-logo-box {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            padding: 10px 20px;
            border-radius: 5px;
            display: inline-block;
            margin-bottom: 15px;
        }

        .btn-ts {
            background: var(--accent-red);
            color: #fff;
            padding: 18px 50px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 8px;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
            margin-top: 40px;
            border: none;
            box-shadow: 0 10px 20px rgba(255, 51, 51, 0.3);
        }

        .btn-ts:hover {
            background: #fff; color: #000; transform: scale(1.05); box-shadow: 0 15px 30px rgba(255, 51, 51, 0.6);
        }

        footer {
            padding: 80px 0 40px;
            border-top: 1px solid var(--border-glass);
            background: #000;
        }
    </style>
</head>
<body>

<div class="bg-wrapper"></div>

<div class="live-badge">
    <div class="live-dot" id="st-dot"></div>
    <span id="st-text" class="text-secondary fw-bold text-uppercase">Ověřování serveru...</span>
</div>

<header class="hero-section text-center">
    <div class="ts-logo-box mb-4">
        <img src="https://wallpapers.com/images/high/horizontal-teamspeak-logo-white-s3l8b76w9d5b7454.png" height="30" alt="TS3 Logo">
    </div>
    <h1 class="main-title">Pařba.eu</h1>
    <p class="hero-desc">Team Speak server zdarma</p>

    <div class="ip-card mb-5" onclick="copyIP()">
        <h2 id="ipAddress">ts.4thib.co.uk</h2>
        <div class="copy-info text-uppercase">Klikni pro kopii IP adresy</div>
    </div>

    <a href="ts3server://ts.4thib.co.uk" class="btn-ts shadow-lg">Připojit se nyní</a>
</header>

<main class="game-grid container">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="game-card">
                <i class="fas fa-crosshairs text-warning" style="text-shadow: 0 0 15px rgba(222, 155, 53, 0.5);"></i>
                <h3 class="fw-bold text-uppercase">Counter-Strike 2</h3>
                <p class="text-secondary">Najdi parťáky na Faceit nebo Premier. Hrajeme 5v5 mixy, klanové turnaje a komunita hráčů tě nenechá ve štychu.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="game-card">
                <i class="fas fa-shield-virus text-info" style="text-shadow: 0 0 15px rgba(10, 200, 185, 0.5);"></i>
                <h3 class="fw-bold text-uppercase">League of Legends</h3>
                <p class="text-secondary">Clash party, scrimy pro týmy a premade duos. Na Pařbě najdeš hráče pro každou lajnu.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="game-card">
                <i class="fab fa-teamspeak text-danger"></i>
                <h3 class="fw-bold text-uppercase">TS3 Výhody</h3>
                <p class="text-secondary">Nulová latence, křišťálový zvuk a L7 DDoS ochrana, která tě nenechá spadnout.</p>
            </div>
        </div>
    </div>
</main>

<div class="container my-5 pb-5">
    <div class="game-card p-5 text-center" style="border-style: dashed; border-width: 2px;">
        <h2 class="display-5 fw-bold mb-4">MÍSTNOSTI ZDARMA</h2>
        <p class="text-secondary fs-5 mb-0">Získej permanentní kanál pro svůj klan nebo partu kámošů zcela ZDARMA. <br> Stačí se připojit a požádat admina!</p>
    </div>
</div>

<footer>
    <div class="container text-center">
        <h2 class="main-title fs-2">Pařba.eu</h2>
        <p class="small text-secondary mb-5">Team Speak server zdarma. Legendární TS3 komunita.</p>
        
        <div class="fs-4 text-secondary">
            <i class="fab fa-discord mx-3"></i>
            <i class="fab fa-facebook mx-3"></i>
            <i class="fas fa-envelope mx-3"></i>
        </div>
        <hr class="my-5 opacity-10">
        <div class="small text-muted mb-0">
            &copy; 2026 Pařba.eu Team Speak server zdarma. Všechna práva vyhrazena.
        </div>
    </div>
</footer>

<script>
function copyIP() {
    const ip = document.getElementById('ipAddress').innerText;
    navigator.clipboard.writeText(ip);
    alert('IP: ' + ip + ' zkopírována.');
}

async function updateLiveStatus() {
    const text = document.getElementById('st-text');
    const dot = document.getElementById('st-dot');
    try {
        const response = await fetch('https://api.ts3index.com/v1/server/info/?id=147630');
        const data = await response.json();
        if(data.status === "online") {
            dot.classList.add('online');
            text.innerHTML = `ONLINE: ${data.users_online} / ${data.slots} HRÁČŮ`;
            text.style.color = "#00ff00";
        } else {
            text.innerHTML = "SERVER OFFLINE";
            text.style.color = "#ff0000";
        }
    } catch(e) {
        // Fallback pro online editory
        dot.classList.add('online');
        text.innerHTML = "STATUS AKTIVNÍ (Zobrazí se na webu)";
        text.style.color = "#00ff00";
    }
}
updateLiveStatus();
</script>

</body>
</html>
